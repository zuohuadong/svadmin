{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.svelte.ts",
    "example/src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
