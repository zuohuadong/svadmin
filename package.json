{
  "name": "svadmin",
  "private": true,
  "type": "module",
  "version": "0.5.14",
  "description": "Headless admin framework for Svelte 5 — bring your own backend",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "example",
    "docs"
  ],
  "scripts": {
    "dev": "cd example && bun run dev",
    "build": "bun run build:packages && bun run --cwd example build && bun run bundle:check",
    "check": "bun run typecheck",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "bun scripts/run-tests.ts",
    "test:e2e": "bun run playwright test",
    "audit": "bun audit",
    "docs:dev": "cd docs && bun run dev",
    "docs:build": "cd docs && bun run build",
    "prepare": "husky",
    "build:packages": "bun run --cwd packages/ui build && bun run --cwd packages/editor build && bun run --cwd packages/lite build && bun run --cwd packages/auth-utils build && bun run --cwd packages/sso build && bun run --cwd packages/create-svadmin build",
    "bundle:check": "bun scripts/check-example-bundle.ts",
    "pack:check": "bun scripts/check-package-packs.ts"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "admin",
    "admin-panel",
    "headless",
    "crud",
    "data-provider",
    "tanstack-query",
    "shadcn-svelte"
  ],
  "license": "MIT",
  "author": "zuohuadong",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zuohuadong/svadmin.git"
  },
  "homepage": "https://github.com/zuohuadong/svadmin#readme",
  "bugs": {
    "url": "https://github.com/zuohuadong/svadmin/issues"
  },
  "devDependencies": {
    "@commitlint/cli": "^21",
    "@commitlint/config-conventional": "^21",
    "@commitlint/types": "^21",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/kit": "2.69.2",
    "@sveltejs/package": "^2.5.8",
    "eslint": "^10.7.0",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17",
    "husky": "^9.1.7",
    "svelte-check": "^4.7.2",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@sveltejs/kit": "2.60.1",
    "astro": "7.0.3",
    "brace-expansion": "5.0.7",
    "cookie": "0.7.2",
    "devalue": "5.8.1",
    "dompurify": "3.4.11",
    "esbuild": "0.28.1",
    "fast-uri": "3.1.3",
    "form-data": "4.0.6",
    "happy-dom": "20.10.6",
    "isomorphic-dompurify": "3.18.0",
    "joi": "17.13.4",
    "js-yaml": "4.3.0",
    "postcss": "8.5.16",
    "qs": "6.15.3",
    "starlight-llms-txt": "0.11.0",
    "svelte": "5.56.4",
    "sveltekit-superforms": "2.30.2",
    "ts-deepmerge": "8.0.0",
    "undici": "7.28.0",
    "vite": "8.0.16",
    "vitest": "4.1.10",
    "ws": "8.21.0"
  }
}
