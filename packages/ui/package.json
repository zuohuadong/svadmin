    "bits-ui": "^2.0.0",
    "clsx": "^2.0.0",
    "cmdk-sv": "^0.0.19",
    "lucide-svelte": "^0.577.0",
    "sonner-svelte": "^0.3.3",
    "tailwind-merge": "^3.0.0",
    "tailwind-variants": "^3.0.0"
  },
