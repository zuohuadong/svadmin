{
  "name": "@svadmin/ui",
  "version": "0.38.4",
  "description": "Pre-built admin UI components — AdminApp, AutoTable, AutoForm, Sidebar, Layout",
  "type": "module",
  "sideEffects": [
    "./dist/app.css"
  ],
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.test-*",
    "!dist/**/*.spec.*",
    "!dist/**/*.spec-*"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./app.css": {
      "svelte": "./dist/app.css",
      "import": "./dist/app.css",
      "style": "./dist/app.css",
      "default": "./dist/app.css"
    },
    "./app.theme.css": {
      "style": "./dist/app.theme.css",
      "default": "./dist/app.theme.css"
    },
    "./components/*.svelte": {
      "types": "./dist/components/*.svelte.d.ts",
      "svelte": "./dist/components/*.svelte",
      "default": "./dist/components/*.svelte"
    },
    "./components/*": "./dist/components/*"
  },
  "peerDependencies": {
    "@svadmin/core": "workspace:*",
    "@tanstack/svelte-query": "^6.1.29",
    "highlight.js": "^11.11.1",
    "isomorphic-dompurify": "^3.15.0",
    "marked": "^18.0.0",
    "marked-highlight": "^2.2.3",
    "svelte": "^5.33.0"
  },
  "peerDependenciesMeta": {
    "marked": {
      "optional": true
    },
    "marked-highlight": {
      "optional": true
    },
    "highlight.js": {
      "optional": true
    },
    "isomorphic-dompurify": {
      "optional": true
    },
    "@svadmin/editor": {
      "optional": true
    },
    "@svadmin/core": {
      "optional": true
    },
    "@tanstack/svelte-query": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "dependencies": {
    "@floating-ui/dom": "^1.8.0",
    "@lucide/svelte": "^1.25.0",
    "@tanstack/svelte-table": "9.0.0-alpha.53",
    "@tanstack/table-core": "9.0.0-alpha.53",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2"
  },
  "license": "MIT",
  "author": "zuohuadong",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/zuohuadong/svadmin#readme",
  "bugs": {
    "url": "https://github.com/zuohuadong/svadmin/issues"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.11.0",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "happy-dom": "^20.11.0",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "build": "svelte-package -i src -o dist && node scripts/postbuild-css.mjs",
    "test": "vitest run --config ./vitest.config.ts"
  }
}
