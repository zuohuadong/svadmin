{
  "name": "@svadmin/ui",
  "version": "0.23.2",
  "description": "Pre-built admin UI components — AdminApp, AutoTable, AutoForm, Sidebar, Layout",
  "type": "module",
  "sideEffects": [
    "./src/app.css"
  ],
  "files": [
    "src/**/*"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./app.css": "./src/app.css",
    "./components/*": "./src/components/*"
  },
  "peerDependencies": {
    "@svadmin/core": "workspace:*",
    "@tanstack/svelte-query": "^6.0.0",
    "highlight.js": "^11.0.0",
    "isomorphic-dompurify": "^2.0.0",
    "marked": "^15.0.0",
    "marked-highlight": "^2.2.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "marked": {
      "optional": true
    },
    "marked-highlight": {
      "optional": true
    },
    "highlight.js": {
      "optional": true
    },
    "isomorphic-dompurify": {
      "optional": true
    },
    "@svadmin/editor": {
      "optional": true
    }
  },
  "dependencies": {
    "@lucide/svelte": "^0.577.0",
