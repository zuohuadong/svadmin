{
  "name": "@svadmin/ui",
  "version": "0.29.1",
  "description": "Pre-built admin UI components — AdminApp, AutoTable, AutoForm, Sidebar, Layout",
  "type": "module",
  "sideEffects": [
    "./src/app.css"
  ],
  "files": [
    "dist/**/*"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js",
      "svelte": "./dist/index.js"
    },
    "./app.css": {
      "style": "./dist/app.css",
      "default": "./dist/app.css",
      "svelte": "./dist/app.css"
    },
    "./components/*": "./dist/components/*"
  },
  "peerDependencies": {
    "@svadmin/core": "workspace:*",
    "@tanstack/svelte-query": "^6.0.0",
    "highlight.js": "^11.11.1",
    "isomorphic-dompurify": "^3.7.1",
    "marked": "^17.0.5",
    "marked-highlight": "^2.2.3",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "marked": {
      "optional": true
    },
    "marked-highlight": {
      "optional": true
    },
    "highlight.js": {
      "optional": true
    },
    "isomorphic-dompurify": {
      "optional": true
    },
    "@svadmin/editor": {
      "optional": true
    }
  },
  "dependencies": {
    "@lucide/svelte": "^1.7.0",
    "@tanstack/svelte-table": "^9.0.0-alpha.10",
    "bits-ui": "^2.17.1",
    "clsx": "^2.1.1",
    "cmdk-sv": "^0.0.19",
    "sonner-svelte": "^0.3.3",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  },
  "license": "MIT",
  "author": "zuohuadong",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/zuohuadong/svadmin#readme",
  "bugs": {
    "url": "https://github.com/zuohuadong/svadmin/issues"
  },
  "devDependencies": {
    "@tanstack/table-core": "8.21.3"
  },
  "scripts": {
    "build": "svelte-package -i src -o dist"
  }
}
