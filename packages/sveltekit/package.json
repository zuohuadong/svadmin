{
  "name": "@svadmin/sveltekit",
  "version": "0.9.2",
  "description": "SvelteKit integration for svadmin",
  "type": "module",
  "sideEffects": false,
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.*",
    "!src/**/*.spec.*",
    "!src/**/vitest.config.*",
    "!src/**/setupTest.*"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "@svadmin/core": "workspace:*",
    "svelte": "^5.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin.git",
    "directory": "packages/sveltekit"
  },
  "peerDependenciesMeta": {
    "@sveltejs/kit": {
      "optional": true
    },
    "@svadmin/core": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  }
}
