{
  "name": "@svadmin/editor",
  "version": "0.1.0",
  "description": "Modern Tiptap-based rich text editor for Svelte 5 — headless, modular, production-ready",
  "type": "module",
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.*",
    "!src/**/*.spec.*",
    "!src/**/vitest.config.*",
    "!src/**/setupTest.*"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components/*": "./src/components/*",
    "./editor.css": "./src/styles/editor.css"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "@svadmin/core": "workspace:*"
  },
  "devDependencies": {
    "@svadmin/core": "workspace:*"
  },
  "dependencies": {
    "@lucide/svelte": "^1.7.0",
    "@tiptap/core": "^3.22.2",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@tiptap/extension-bubble-menu": "^3.22.2",
    "@tiptap/extension-character-count": "^3.22.2",
    "@tiptap/extension-code-block-lowlight": "^3.22.2",
    "@tiptap/extension-color": "^3.22.2",
    "@tiptap/extension-floating-menu": "^3.22.2",
    "@tiptap/extension-highlight": "^3.22.2",
    "@tiptap/extension-image": "^3.22.2",
    "@tiptap/extension-link": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/extension-subscript": "^3.22.2",
    "@tiptap/extension-superscript": "^3.22.2",
    "@tiptap/extension-table": "^3.22.2",
    "@tiptap/extension-table-cell": "^3.22.2",
    "@tiptap/extension-table-header": "^3.22.2",
    "@tiptap/extension-table-row": "^3.22.2",
    "@tiptap/extension-task-item": "^3.22.2",
    "@tiptap/extension-task-list": "^3.22.2",
    "@tiptap/extension-text-align": "^3.22.2",
    "@tiptap/extension-text-style": "^3.22.2",
    "@tiptap/extension-typography": "^3.22.2",
    "@tiptap/extension-underline": "^3.22.2",
    "@tiptap/suggestion": "^3.22.2",
    "lowlight": "^3.3.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "zuohuadong",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin.git",
    "directory": "packages/editor"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    },
    "@svadmin/core": {
      "optional": true
    }
  }
}
