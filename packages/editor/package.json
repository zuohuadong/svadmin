    "@tiptap/extension-text-style": "^2.12.0",
    "@tiptap/extension-typography": "^2.12.0",
    "@tiptap/extension-underline": "^2.12.0",
    "@tiptap/suggestion": "^2.12.0",
    "lowlight": "^3.3.0",
    "lucide-svelte": "^0.577.0"
