{
  "name": "@svadmin/editor",
  "version": "0.1.0",
  "description": "Modern Tiptap-based rich text editor for Svelte 5 — headless, modular, production-ready",
  "type": "module",
  "files": [
    "src/**/*"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components/*": "./src/components/*",
    "./editor.css": "./src/styles/editor.css"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "@svadmin/core": "^0.19.3"
  },
  "devDependencies": {
    "@svadmin/core": "^0.19.3"
  },
  "dependencies": {
    "@tiptap/core": "^2.12.0",
    "@tiptap/pm": "^2.12.0",
    "@tiptap/starter-kit": "^2.12.0",
    "@tiptap/extension-bubble-menu": "^2.12.0",
    "@tiptap/extension-character-count": "^2.12.0",
    "@tiptap/extension-code-block-lowlight": "^2.12.0",
    "@tiptap/extension-color": "^2.12.0",
    "@tiptap/extension-floating-menu": "^2.12.0",
    "@tiptap/extension-highlight": "^2.12.0",
    "@tiptap/extension-image": "^2.12.0",
    "@tiptap/extension-link": "^2.12.0",
    "@tiptap/extension-placeholder": "^2.12.0",
