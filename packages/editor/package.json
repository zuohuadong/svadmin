{
  "name": "@svadmin/editor",
  "version": "0.2.1",
  "description": "Modern Tiptap-based rich text editor for Svelte 5 — headless, modular, production-ready",
  "type": "module",
  "sideEffects": [
    "./dist/styles/editor.css"
  ],
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.test-*",
    "!dist/**/*.spec.*",
    "!dist/**/*.spec-*"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components/*.svelte": {
      "types": "./dist/components/*.svelte.d.ts",
      "svelte": "./dist/components/*.svelte",
      "default": "./dist/components/*.svelte"
    },
    "./components/*": "./dist/components/*",
    "./editor.css": {
      "svelte": "./dist/styles/editor.css",
      "style": "./dist/styles/editor.css",
      "import": "./dist/styles/editor.css",
      "default": "./dist/styles/editor.css"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "@svadmin/core": "workspace:*"
  },
  "devDependencies": {
    "@svadmin/core": "workspace:*"
  },
  "dependencies": {
    "@lucide/svelte": "^1.24.0",
    "@tiptap/core": "^3.27.3",
    "@tiptap/extension-bubble-menu": "^3.27.3",
    "@tiptap/extension-character-count": "^3.27.3",
    "@tiptap/extension-code-block-lowlight": "^3.27.3",
    "@tiptap/extension-color": "^3.27.3",
    "@tiptap/extension-floating-menu": "^3.27.3",
    "@tiptap/extension-highlight": "^3.27.3",
    "@tiptap/extension-image": "^3.27.3",
    "@tiptap/extension-link": "^3.27.3",
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/extension-subscript": "^3.27.3",
    "@tiptap/extension-superscript": "^3.27.3",
    "@tiptap/extension-table": "^3.27.3",
    "@tiptap/extension-table-cell": "^3.27.3",
    "@tiptap/extension-table-header": "^3.27.3",
    "@tiptap/extension-table-row": "^3.27.3",
    "@tiptap/extension-task-item": "^3.27.3",
    "@tiptap/extension-task-list": "^3.27.3",
    "@tiptap/extension-text-align": "^3.27.3",
    "@tiptap/extension-text-style": "^3.27.3",
    "@tiptap/extension-typography": "^3.27.3",
    "@tiptap/extension-underline": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "@tiptap/suggestion": "^3.27.3",
    "lowlight": "^3.3.0"
  },
  "scripts": {
    "build": "svelte-package -i src -o dist"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "zuohuadong",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin.git",
    "directory": "packages/editor"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    },
    "@svadmin/core": {
      "optional": true
    }
  }
}
