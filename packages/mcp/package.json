{
  "name": "@svadmin/mcp",
  "version": "0.2.5",
  "description": "MCP (Model Context Protocol) server — expose svadmin DataProvider as tools for AI agents",
  "type": "module",
  "sideEffects": false,
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.*",
    "!src/**/*.spec.*",
    "!src/**/vitest.config.*",
    "!src/**/setupTest.*"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "peerDependencies": {
    "@svadmin/core": "workspace:*"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "zuohuadong",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/zuohuadong/svadmin#readme",
  "bugs": {
    "url": "https://github.com/zuohuadong/svadmin/issues"
  },
