{
  "name": "@svadmin/simple-rest",
  "version": "0.9.6",
  "description": "Simple REST adapters — fetch-based DataProvider and JWT/Cookie AuthProvider",
  "type": "module",
  "sideEffects": false,
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.*",
    "!src/**/*.spec.*",
    "!src/**/vitest.config.*",
    "!src/**/setupTest.*"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "peerDependencies": {
    "@svadmin/core": "workspace:*",
    "@refinedev/simple-rest": "^5.0.0"
  },
  "license": "MIT",
  "author": "zuohuadong",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin.git",
    "directory": "packages/simple-rest"
  },
  "homepage": "https://github.com/zuohuadong/svadmin#readme",
  "bugs": {
    "url": "https://github.com/zuohuadong/svadmin/issues"
  },
  "peerDependenciesMeta": {
    "@svadmin/core": {
      "optional": true
    },
    "@refinedev/simple-rest": {
      "optional": true
    }
  },
  "dependencies": {
    "@svadmin/refine-adapter": "workspace:*"
  }
}
