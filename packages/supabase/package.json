{
  "name": "@svadmin/supabase",
  "version": "0.11.1",
  "description": "Supabase adapters — DataProvider, AuthProvider, LiveProvider, AuditHandler",
  "type": "module",
  "sideEffects": false,
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.*",
    "!src/**/*.spec.*",
    "!src/**/vitest.config.*",
    "!src/**/setupTest.*"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./supacloud": {
      "types": "./src/supacloud.ts",
      "default": "./src/supacloud.ts"
    }
  },
  "peerDependencies": {
    "@svadmin/core": "workspace:*",
    "@supabase/supabase-js": "^2.0.0",
    "@refinedev/supabase": "^5.0.0",
    "@supacloud/js": "^0.12.0"
  },
  "license": "MIT",
  "author": "zuohuadong",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin.git",
    "directory": "packages/supabase"
  },
  "homepage": "https://github.com/zuohuadong/svadmin#readme",
  "bugs": {
    "url": "https://github.com/zuohuadong/svadmin/issues"
  },
  "peerDependenciesMeta": {
    "@svadmin/core": {
      "optional": true
    },
    "@supabase/supabase-js": {
      "optional": true
    },
    "@refinedev/supabase": {
      "optional": true
    },
    "@supacloud/js": {
      "optional": true
    }
  },
  "dependencies": {
    "@svadmin/refine-adapter": "workspace:*"
  }
}
