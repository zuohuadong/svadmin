{
  "name": "@svadmin/refine-adapter",
  "version": "0.9.4",
  "description": "Universal Refine DataProvider adapter for svadmin",
  "type": "module",
  "sideEffects": false,
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.*",
    "!src/**/*.spec.*",
    "!src/**/vitest.config.*",
    "!src/**/setupTest.*"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "peerDependencies": {
    "@svadmin/core": "workspace:*"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin.git",
    "directory": "packages/refine-adapter"
  },
  "peerDependenciesMeta": {
    "@svadmin/core": {
      "optional": true
    }
  }
}
