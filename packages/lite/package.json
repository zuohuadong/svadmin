{
  "name": "@svadmin/lite",
  "version": "0.3.9",
  "description": "SSR-first lightweight admin UI for @svadmin with optional progressive enhancement",
  "type": "module",
  "sideEffects": [
    "./dist/lite.css",
    "./dist/enhance.js"
  ],
  "files": [
    "dist",
    "README.md",
    "!dist/**/*.test.*",
    "!dist/**/*.test-*",
    "!dist/**/*.spec.*",
    "!dist/**/*.spec-*"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components/*.svelte": {
      "types": "./dist/components/*.svelte.d.ts",
      "svelte": "./dist/components/*.svelte",
      "default": "./dist/components/*.svelte"
    },
    "./components/*": "./dist/components/*",
    "./enhance.js": {
      "import": "./dist/enhance.js",
      "default": "./dist/enhance.js"
    },
    "./lite.css": {
      "svelte": "./dist/lite.css",
      "style": "./dist/lite.css",
      "import": "./dist/lite.css",
      "default": "./dist/lite.css"
    },
    "./src/lite.css": {
      "svelte": "./dist/lite.css",
      "style": "./dist/lite.css",
      "import": "./dist/lite.css",
      "default": "./dist/lite.css"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "@svadmin/core": "workspace:*",
    "@sveltejs/kit": "^2.0.0"
  },
  "dependencies": {
    "@lucide/svelte": "^1.25.0",
    "sveltekit-superforms": "^2.30.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.11.0",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/svelte": "^5.4.2",
    "happy-dom": "^20.11.0",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "build": "svelte-package -i src -o dist && bun ../../scripts/copy-package-assets.ts static/enhance.js dist/enhance.js",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "zuohuadong",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin.git",
    "directory": "packages/lite"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    },
    "@svadmin/core": {
      "optional": true
    },
    "@sveltejs/kit": {
      "optional": true
    }
  }
}
