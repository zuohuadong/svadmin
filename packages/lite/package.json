{
  "name": "@svadmin/lite",
  "version": "0.3.5",
  "description": "SSR-compatible lightweight admin UI for @svadmin — zero client-side JS, works in IE11",
  "type": "module",
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.*",
    "!src/**/*.spec.*",
    "!src/**/vitest.config.*",
    "!src/**/setupTest.*"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "svelte": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./enhance.js": "./static/enhance.js",
    "./src/lite.css": "./src/lite.css"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "@svadmin/core": "workspace:*",
    "@sveltejs/kit": "^2.0.0"
  },
  "dependencies": {
    "@lucide/svelte": "^1.7.0",
    "sveltekit-superforms": "^2.30.1",
    "zod": "^4.3.6"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "zuohuadong",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin.git",
    "directory": "packages/lite"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    },
    "@svadmin/core": {
      "optional": true
    },
    "@sveltejs/kit": {
      "optional": true
    }
  }
}
