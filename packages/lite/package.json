{
  "name": "@svadmin/lite",
  "version": "0.2.2",
  "description": "SSR-compatible lightweight admin UI for @svadmin — zero client-side JS, works in IE11",
  "type": "module",
  "files": [
    "src/**/*",
    "static/**/*"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "svelte": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./enhance.js": "./static/enhance.js",
    "./src/lite.css": "./src/lite.css"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "@svadmin/core": "workspace:*",
    "@sveltejs/kit": "^2.0.0"
  },
  "dependencies": {
    "sveltekit-superforms": "^2.22.0",
    "zod": "^3.24.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "zuohuadong",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin.git",
    "directory": "packages/lite"
  }
}
