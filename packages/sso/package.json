{
  "name": "@svadmin/sso",
  "version": "0.11.1",
  "type": "module",
  "description": "OIDC/OAuth2 SSO AuthProvider plugin for svadmin — supports Okta, Azure AD, Cognito, Keycloak, Google",
  "license": "MIT",
  "keywords": [
    "svadmin",
    "sso",
    "oidc",
    "oauth2",
    "okta",
    "azure-ad",
    "cognito",
    "keycloak"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin",
    "directory": "packages/sso"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@svadmin/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "bun ../../scripts/build-node-package.ts"
  },
  "peerDependenciesMeta": {
    "@svadmin/core": {
      "optional": true
    }
  }
}
