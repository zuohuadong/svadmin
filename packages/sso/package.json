{
  "name": "@svadmin/sso",
  "version": "0.8.8",
  "type": "module",
  "description": "OIDC/OAuth2 SSO AuthProvider plugin for svadmin — supports Okta, Azure AD, Cognito, Keycloak, Google",
  "license": "MIT",
  "keywords": [
    "svadmin",
    "sso",
    "oidc",
    "oauth2",
    "okta",
    "azure-ad",
    "cognito",
    "keycloak"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin",
    "directory": "packages/sso"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.*",
    "!src/**/*.spec.*",
    "!src/**/vitest.config.*",
    "!src/**/setupTest.*"
  ],
  "peerDependencies": {
    "@svadmin/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "peerDependenciesMeta": {
    "@svadmin/core": {
      "optional": true
    }
  }
}
