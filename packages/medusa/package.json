{
  "name": "@svadmin/medusa",
  "version": "0.9.6",
  "description": "Medusa DataProvider for svadmin",
  "type": "module",
  "sideEffects": false,
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.*",
    "!src/**/*.spec.*",
    "!src/**/vitest.config.*",
    "!src/**/setupTest.*"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "peerDependencies": {
    "@svadmin/core": "workspace:*",
    "@refinedev/medusa": "^5.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/svadmin.git",
    "directory": "packages/medusa"
  },
  "peerDependenciesMeta": {
    "@svadmin/core": {
      "optional": true
    },
    "@refinedev/medusa": {
      "optional": true
    }
  },
  "dependencies": {
    "@svadmin/refine-adapter": "workspace:*"
  }
}
